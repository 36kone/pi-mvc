@model PizzaMvc.Controllers.HomeSearchViewModel

@{
    ViewBag.Title = "Busca";
    Layout = "_Layout";
}

<main>
    <section class="section">
        <div class="container">
            <div class="section__header">
                <h2>Resultados</h2>
                <a class="btn btn--outline" href="@Url.Action("Index", "Home")">Voltar</a>
            </div>

            <div class="surface" style="padding:16px; margin-bottom:16px;">
                <strong>Busca:</strong> @Model.Query
            </div>

            <div class="surface" style="padding:16px; margin-bottom:24px;">
                <form class="search-box" method="get" action="@Url.Action("Search", "Home")">
                    <div class="search-box__field">
                        <span class="search-box__icon">🔍</span>
                        <input type="text" name="q" value="@Model.Query" placeholder="Buscar por nome..." />
                    </div>
                    <button type="submit" class="btn btn--secondary">Buscar</button>
                </form>
            </div>

            @{
                var results = new List<(string Tipo, int Id, string Nome, string Resumo, decimal Preco, string Image, string Entity, string Url)>();

                foreach (var pizza in Model.Pizzas)
                {
                    var resumo = string.Join(" • ", new[] { pizza.Categoria, pizza.Sabor }.Where(s => !string.IsNullOrWhiteSpace(s)));
                    var image = !string.IsNullOrWhiteSpace(pizza.Image) ? pizza.Image : "/imgs/pizza%20panceta.jpeg";
                    results.Add(("Pizza", pizza.Id, pizza.Nome ?? string.Empty, resumo, pizza.Preco, image, "pizza", Url.Action("GetById", "Pizza", new { id = pizza.Id }) ?? string.Empty));
                }

                foreach (var bebida in Model.Bebidas)
                {
                    var resumo = string.Join(" • ", new[] { bebida.Categoria, bebida.Sabor }.Where(s => !string.IsNullOrWhiteSpace(s)));
                    var image = !string.IsNullOrWhiteSpace(bebida.Image) ? bebida.Image : "/imgs/shared%20image%20(6).jpeg";
                    results.Add(("Bebida", bebida.Id, bebida.Nome ?? string.Empty, resumo, bebida.Preco, image, "bebida", Url.Action("GetById", "Bebida", new { id = bebida.Id }) ?? string.Empty));
                }

                foreach (var evento in Model.Eventos)
                {
                    var dataTexto = evento.DataEvento == default ? string.Empty : evento.DataEvento.ToString("dd/MM/yyyy");
                    var resumo = string.Join(" • ", new[] { dataTexto, evento.Local }.Where(s => !string.IsNullOrWhiteSpace(s)));
                    var image = !string.IsNullOrWhiteSpace(evento.Image) ? evento.Image : "/imgs/reserva_evento.jpeg";
                    results.Add(("Evento", evento.Id, evento.Nome ?? string.Empty, resumo, 0m, image, "evento", Url.Action("GetById", "Evento", new { id = evento.Id }) ?? string.Empty));
                }
            }

            <div class="surface" style="padding:16px;">
                <div class="section__header" style="margin-bottom:12px;">
                    <h2>Resultados encontrados</h2>
                </div>

                @if (results.Count == 0)
                {
                    <div class="empty-state">
                        <h3>Nenhum resultado encontrado</h3>
                        <p>Tente outra palavra-chave.</p>
                    </div>
                }
                else
                {
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>Carrinho</th>
                                <th>Visualizar</th>
                                <th>Tipo</th>
                                <th>Nome</th>
                                <th>Resumo</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in results)
                            {
                                var canAddToCart = row.Entity == "pizza" || row.Entity == "bebida";
                                <tr>
                                    <td>
                                        @if (canAddToCart)
                                        {
                                            <button type="button"
                                                    class="btn btn--ghost btn--sm js-add-to-cart"
                                                    aria-label="Adicionar ao carrinho"
                                                    data-entity="@row.Entity"
                                                    data-id="@row.Id"
                                                    data-name="@row.Nome"
                                                    data-summary="@row.Resumo"
                                                    data-price="@row.Preco.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                                                    data-image="@row.Image">🛒 +</button>
                                        }
                                    </td>
                                    <td>
                                        <button type="button"
                                                class="btn btn--secondary btn--sm js-view-entity"
                                                data-entity="@row.Entity"
                                                data-url="@row.Url">
                                            Visualizar
                                        </button>
                                    </td>
                                    <td>@row.Tipo</td>
                                    <td>@row.Nome</td>
                                    <td>@row.Resumo</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </section>
</main>
