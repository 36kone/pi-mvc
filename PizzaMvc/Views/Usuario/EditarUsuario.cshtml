@model PizzaMvc.Models.Usuario
@{
    ViewBag.Title = "Editar Usuário";
}

<h2>Editar Usuário</h2>
<form method="post" action="/Usuario/Edit">
    <input type="hidden" name="Id" value="@Model.Id" />
    <div class="mb-3">
        <label>Nome</label>
        <input name="Nome" class="form-control" value="@Model.Nome" required />
    </div>
    <div class="mb-3">
        <label>Email</label>
        <input name="Email" type="email" class="form-control" value="@Model.Email" required />
    </div>
    <div class="mb-3">
        <label>Senha</label>
        <input name="Senha" type="password" class="form-control" placeholder="Deixe em branco para manter a senha atual" />
    </div>
    <div class="mb-3">
        <label>Tipo</label>
        <select name="Tipo" class="form-control">
            <option value="Admin" selected="@(Model.Tipo == "Admin")">Admin</option>
            <option value="Usuario" selected="@(Model.Tipo == "Usuario")">Usuário</option>
        </select>
    </div>
    <button type="submit" class="btn btn-success">Salvar</button>
    <a href="/Usuario" class="btn btn-secondary">Voltar</a>
</form>
