@model IEnumerable<PizzaMvc.Models.Pizza>
@{
    ViewBag.Title = "Pizzas";
}

<section class="section">
    <div class="section__header">
        <h2>Pizzas</h2>
        <div class="actions-bar">
            <a class="btn btn--outline" href="@Url.Action("Index", "Admin")">Admin</a>
            <a class="btn btn--primary" href="@Url.Action("Create", "Pizza")">Nova Pizza</a>
        </div>
    </div>

    @if (Model?.Any() != true)
    {
        <div class="surface empty-state">
            <h3>Nenhuma pizza cadastrada</h3>
            <p>Cadastre uma pizza para ela aparecer aqui.</p>
            <a class="btn btn--primary" href="@Url.Action("Create", "Pizza")">Cadastrar Pizza</a>
        </div>
    }
    else
    {
        <table class="data-table">
            <thead>
                <tr>
                    <th></th>
                    <th>Nome</th>
                    <th>Sabor</th>
                    <th>Preço</th>
                    <th>Categoria</th>
                    <th>Ações</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            @if (!string.IsNullOrWhiteSpace(item.Image))
                            {
                                <img class="thumb" src="@item.Image" alt="@item.Nome" />
                            }
                        </td>
                        <td>@item.Nome</td>
                        <td>@item.Sabor</td>
                        <td>@item.Preco.ToString("C")</td>
                        <td>@item.Categoria</td>
                        <td>
                            <div class="data-table__actions">
                                <button type="button" class="btn btn--sm btn--outline js-view-entity" data-entity="pizza" data-id="@item.Id" data-url="@Url.Action("GetById", "Pizza", new { id = item.Id })">Visualizar</button>
                                <a class="btn btn--sm btn--warning" href="@Url.Action("Edit", "Pizza", new { id = item.Id })">Editar</a>
                                <form action="@Url.Action("DeleteConfirmed", "Pizza", new { id = item.Id })" method="post">
                                    <input type="hidden" name="_method" value="DELETE">
                                    <button class="btn btn--sm btn--danger" onclick="return confirm('Confirma?')">Excluir</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</section>
