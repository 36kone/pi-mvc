@model PizzaMvc.Models.Pizza
@{
    ViewBag.Title = "Excluir Pizza";
}

<h2>Excluir Pizza</h2>
<p>Confirma exclusão de <strong>@Model.Nome</strong>?</p>
<form method="post" action="/Pizza/DeleteConfirmed/@Model.Id">
    <input type="hidden" name="_method" value="DELETE">
    <button type="submit" class="btn btn-danger">Confirmar</button>
    <a href="/Pizza" class="btn btn-secondary">Voltar</a>
</form>
