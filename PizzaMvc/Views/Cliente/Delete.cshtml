@model PizzaMvc.Models.Cliente
@{
    ViewBag.Title = "Excluir Cliente";
}

<h2>Excluir Cliente</h2>
<p>Confirma exclusão de <strong>@Model.Nome</strong>?</p>
<form method="post" action="/Cliente/DeleteConfirmed/@Model.Id">
    <input type="hidden" name="_method" value="DELETE">
    <button type="submit" class="btn btn-danger">Confirmar</button>
    <a href="/Cliente" class="btn btn-secondary">Voltar</a>
</form>
